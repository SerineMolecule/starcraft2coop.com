            "type": "array",
            "items": {
                "$ref": "#/definitions/MutatorCommanderTip"
            }
        },
        "MutatorCommanderTip": {
            "type": "object",
            "properties": {
                "tipid": {
                    "$ref": "#/definitions/PositiveInteger"
                },
                "mutator": {
                    "$ref": "#/definitions/PositiveInteger"
                },
                "commander": {
                    "type": "string"
                },
                "tip": {
                    "type": "string"
                },
                "video": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "tipid",
                "mutator",
                "commander",
                "tip",
                "video"
            ],
            "additionalProperties": false
        },
        "PositiveInteger": {
            "type": "integer",
            "minimum": 1
        }
    }
