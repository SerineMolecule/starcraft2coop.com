{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$ref": "#/definitions/MutatorInteractionList",
    "definitions": {
        "MutatorInteractionList": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/MutatorInteraction"
            }
        },
        "MutatorInteraction": {
            "type": "object",
            "properties": {
                "id1": {
                    "$ref": "#/definitions/MutatorId",
                    "description": "ID of the first mutator in the pair, lowercased & without spaces"
                },
                "id2": {
                    "$ref": "#/definitions/MutatorId",
                    "description": "ID of the second mutator in the pair, lowercased & without spaces, id2 > id1"
                },
                "interaction": {
                    "type": "string",
                    "description": "Description of how the two mutators interact"
                }
            },
            "required": [
                "id1",
                "id2",
                "interaction"
            ],
            "additionalProperties": false
        },
        "MutatorId": {
            "$ref": "#/definitions/LowercaseNoSpaces"
        },
        "LowercaseNoSpaces": {
            "type": "string",
            "pattern": "^[^ A-Z]+$"
        }
    }
}
